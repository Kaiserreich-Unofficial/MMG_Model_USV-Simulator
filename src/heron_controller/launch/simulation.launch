<launch>
    <!-- 加载整个 YAML 文件 -->
    <rosparam command="load" file="$(find heron_controller)/config/config.yaml" />
    <!-- 启动节点 -->
    <node name="mppi_controller" pkg="heron_controller" type="mppi_controller" output="screen" />
    <!-- 启动轨迹生成 -->
    <node pkg="heron_controller" type="traj_generator.py" name="TrajGenerator" output="screen"/>
  </launch>
